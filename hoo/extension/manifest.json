{
  "manifest_version": 3,
  "name": "Hoo LinkedIn Saver",
  "version": "1.0.0",
  "description": "Scrape LinkedIn profiles and save to Hoo.",
  "permissions": [],
  "host_permissions": ["https://www.linkedin.com/*", "https://hoopeople.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

